    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>OutSystems.ExternalLibraries.GoogleCloudStorage_Connector</RootNamespace>
    <AssemblyName>OutSystems.ExternalLibraries.GoogleCloudStorage_Connector</AssemblyName>
